# ───────────────────────────────────────────────
#  CardioVision — .gitignore
# ───────────────────────────────────────────────

# ── Python byte-code ──────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environment ───────────────────────
ENV/
env/
venv/
.venv/
.conda/

# ── Frontend toolchain ────────────────────────
# node_modules is always re-installed from package.json
frontend/node_modules/
# Vite local dev cache
frontend/.vite/

# ── Built frontend assets ─────────────────────
# app/static/ contains the Vite production build.
# It IS committed so Railway/Docker can serve the
# SPA without running a separate npm build step.
# Do NOT add app/static/ here.

# ── Runtime: uploaded patient files ──────────
# NIfTI files uploaded by users — never commit patient data.
uploads/

# ── Runtime: job state + generated outputs ───
# All results (state.json, GIFs, PNGs) are generated
# at runtime and are patient-specific.
jobs/

# ── Stale pipeline outputs (root-level) ───────
# Generated when running src/main_pipeline.py directly.
outputs/

# ── Environment variables ─────────────────────
.env
.env.*
!.env.example

# ── IDE / editor ──────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter ───────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Pytest / coverage ─────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Logs ──────────────────────────────────────
*.log
logs/
