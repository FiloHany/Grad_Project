      vertex="1" parent="1">
      <mxGeometry x="75" y="726" width="1019" height="160" as="geometry" />
    </mxCell>
    <mxCell id="110H" value="src/  —  ML Pipeline  (READ ONLY — zero modifications)"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#059669;strokeColor=#059669;fontColor=#ffffff;fontSize=10;fontStyle=1;align=center;"
      vertex="1" parent="1">
      <mxGeometry x="75" y="726" width="1019" height="26" as="geometry" />
    </mxCell>
    <mxCell id="111" value="predictors/&#xa;load_segmentation_model()&#xa;predict_masks()&#xa;  → nnU-Net + Deep Supervision&#xa;  → 4 classes: BG / LV / Myocardium / LA&#xa;  → frame-wise, resized to 384×384&#xa;predict_ef_video_model()&#xa;  → R(2+1)D-18 + Spatial+Temporal Attn&#xa;  → 48-frame clip centered on ES&#xa;  → outputs EF% directly"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#059669;fontSize=9;align=left;spacingLeft=6;verticalAlign=top;spacingTop=4;"
      vertex="1" parent="1">
      <mxGeometry x="90" y="760" width="300" height="115" as="geometry" />
    </mxCell>
    <mxCell id="112" value="postprocessing/&#xa;run_pipeline()&#xa;  → Biplane Simpson per frame&#xa;  → Volume curve over all frames&#xa;  → ED = argmax(volumes)&#xa;  → ES = argmin(volumes)&#xa;  → EDV, ESV, EF, SV, FAC&#xa;  → LV area, LA area, LA EF&#xa;get_ef_class()&#xa;  → Normal/Mild/Moderate/Severe"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#059669;fontSize=9;align=left;spacingLeft=6;verticalAlign=top;spacingTop=4;"
      vertex="1" parent="1">
      <mxGeometry x="405" y="760" width="300" height="115" as="geometry" />
    </mxCell>
    <mxCell id="113" value="visualization/&#xa;create_gifs()&#xa;  → original.gif (raw sequence)&#xa;  → overlay.gif (segmentation contours)&#xa;  → LV=Blue, Myocardium=Green, LA=Red&#xa;visualize_ed_es()&#xa;  → ED_original.png + ED_overlay.png&#xa;  → ES_original.png + ES_overlay.png&#xa;Writes all files to:  outputs/ (repo root)"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#059669;fontSize=9;align=left;spacingLeft=6;verticalAlign=top;spacingTop=4;"
      vertex="1" parent="1">
      <mxGeometry x="720" y="760" width="360" height="115" as="geometry" />
    </mxCell>

