# ─────────────────────────────────────────────────────────────────────────────
#  CardioVision — environment variables reference
#
#  Copy this file to .env for local overrides (never commit .env).
#  On Railway / other PaaS: set these in the "Variables" dashboard tab.
# ─────────────────────────────────────────────────────────────────────────────

# Port the server listens on.
# Railway sets this automatically — do NOT override it there.
# For local dev the default is 8000 (set in run.py).
# PORT=8000

# Set to "true" to hide /docs and /redoc Swagger UI.
# Recommended for hospital / production deployments.
# DISABLE_DOCS=true

# Unbuffered Python output — keeps Railway/Docker logs readable in real time.
PYTHONUNBUFFERED=1
